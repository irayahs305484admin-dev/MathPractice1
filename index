</head>
<body>
    <div id="root"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-auth.js";
        import { getFirestore, collection, addDoc, getDocs } from "https://www.gstatic.com/firebasejs/12.12.1/firebase-firestore.js";

        // Your web app's Firebase configuration
        const firebaseConfig = {
            apiKey: "AIzaSyAVreTA-PDMyZkBQ_tC12E67YgoEP7lJpA",
            authDomain: "mathpractice1-9a4bd.firebaseapp.com",
            projectId: "mathpractice1-9a4bd",
            storageBucket: "mathpractice1-9a4bd.firebasestorage.app",
            messagingSenderId: "363903265111",
            appId: "1:363903265111:web:5a14ba6f7197267ba47612"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        
        // Keep these variables for the platform's specific paths and authentication
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'math-practice-default';
        const initialAuthToken = typeof __initial_auth_token !== 'undefined' ? __initial_auth_token : null;

        // Make Firebase available to React
        window.FirebaseApp = { db, auth, appId, signInAnonymously, signInWithCustomToken, initialAuthToken, collection, addDoc, getDocs };
    </script>

    <script type="text/babel">
        const { useState, useEffect, useMemo, useRef } = React;

        // Utility: Random Integer
        const randomInt = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

        // --- MATH GENERATORS ---

        const gcd = (a, b) => b === 0 ? a : gcd(b, a % b);

        const generateNoRegroupingAdd = (digits) => {
            let aStr = '', bStr = '';
            for (let i = 0; i < digits; i++) {
                const maxD1 = i === 0 ? 9 : 9;
                const minD1 = i === 0 ? 1 : 0;
                const d1 = randomInt(minD1, maxD1);
                const maxD2 = 9 - d1;
                const minD2 = i === 0 && d1 === 9 ? 0 : (i===0 ? 1 : 0); // avoid leading zero
                const d2 = randomInt(Math.min(minD2, maxD2), maxD2);
                aStr += d1;
                bStr += d2;
            }
            return { a: parseInt(aStr), b: parseInt(bStr) };
        };

        const generateNoRegroupingSub = (digits) => {
            let aStr = '', bStr = '';
            for (let i = 0; i < digits; i++) {
                const maxD1 = 9;
                const minD1 = i === 0 ? 1 : 0;
                const d1 = randomInt(minD1, maxD1);
                const minD2 = i === 0 ? 1 : 0;
                const d2 = randomInt(minD2, d1);
                aStr += d1;
                bStr += d2;
            }
            return { a: parseInt(aStr), b: parseInt(bStr) };
        };

        const generateNumber = (digits, regrouping, op) => {
            if (regrouping === 'no' && op === '+') return generateNoRegroupingAdd(digits);
            if (regrouping === 'no' && op === '-') return generateNoRegroupingSub(digits);
            
            // Standard/Mixed generation
            const min = Math.pow(10, digits - 1);
            const max = Math.pow(10, digits) - 1;
            let a = randomInt(min, max);
            let b = randomInt(min, max);
            
            if (op === '-' && b > a) {
                let temp = a; a = b; b = temp;
            }
            return { a, b };
        };

        const FractionDisplay = ({ num, den, sign = '' }) => (
            <div className="inline-flex items-center gap-2 mx-1 align-middle text-xl">
                {sign && <span>{sign}</span>}
                <div className="flex flex-col items-center leading-tight">
                    <span className="px-1 border-b-2 border-black w-full text-center">{num}</span>
                    <span className="px-1 w-full text-center">{den}</span>
                </div>
            </div>
        );

        // Main Generator Router
        const generateQuestion = (topic, settings) => {
            const { digits, regrouping, sign, table } = settings;

            // Apply Sign Logic
            const applySign = (val) => {
                if (sign === 'positive') return Math.abs(val);
                if (sign === 'negative') return -Math.abs(val);
                return randomInt(0, 1) === 0 ? val : -val; // Mixed
            };

            const formatVal = (v) => v < 0 ? `(${v})` : v;

            switch (topic) {
                case 'whole_add':
                case 'int_add': {
                    const { a, b } = generateNumber(digits, regrouping, '+');
                    let finalA = topic === 'int_add' ? applySign(a) : a;
                    let finalB = topic === 'int_add' ? applySign(b) : b;
                    return {
                        text: `${formatVal(finalA)} + ${formatVal(finalB)}`,
                        answer: (finalA + finalB).toString(),
                        type: 'standard',
                        displayAnswer: (finalA + finalB).toString()
                    };
                }
                case 'whole_sub':
                case 'int_sub': {
                    const { a, b } = generateNumber(digits, regrouping, '-');
                    let finalA = topic === 'int_sub' ? applySign(a) : a;
                    let finalB = topic === 'int_sub' ? applySign(b) : b;
                    return {
                        text: `${formatVal(finalA)} - ${formatVal(finalB)}`,
                        answer: (finalA - finalB).toString(),
                        type: 'standard',
                        displayAnswer: (finalA - finalB).toString()
                    };
                }
                case 'whole_mul':
                case 'int_mul': {
                    let a, b;
                    if (table === 'mixed') {
                        a = randomInt(1, Math.pow(10, digits) - 1);
                        b = randomInt(1, Math.pow(10, digits) - 1);
                    } else {
                        a = parseInt(table);
                        b = randomInt(1, 12);
                        if (randomInt(0,1)) { let temp = a; a = b; b = temp; }
                    }
                    let finalA = topic === 'int_mul' ? applySign(a) : a;
                    let finalB = topic === 'int_mul' ? applySign(b) : b;
                    return {
                        text: `${formatVal(finalA)} × ${formatVal(finalB)}`,
                        answer: (finalA * finalB).toString(),
                        type: 'standard',
                        displayAnswer: (finalA * finalB).toString()
                    };
                }
                case 'whole_div':
                case 'int_div': {
                    let divisor, quotient;
                    if (table === 'mixed') {
                        divisor = randomInt(1, Math.pow(10, digits) - 1);
                        quotient = randomInt(1, 12);
                    } else {
                        divisor = parseInt(table);
                        quotient = randomInt(1, 12);
                    }
                    let finalDivisor = topic === 'int_div' ? applySign(divisor) : divisor;
                    let finalQuotient = topic === 'int_div' ? applySign(quotient) : quotient;
                    if(finalDivisor === 0) finalDivisor = 1;
                    let finalDividend = finalDivisor * finalQuotient;

                    return {
                        text: `${formatVal(finalDividend)} ÷ ${formatVal(finalDivisor)}`,
                        answer: finalQuotient.toString(),
                        type: 'standard',
                        displayAnswer: finalQuotient.toString()
                    };
                }
                case 'dec_add':
                case 'dec_sub': {
                    const op = topic === 'dec_add' ? '+' : '-';
                    const { a, b } = generateNumber(digits, regrouping, op);
                    const decPlace = randomInt(1, digits);
                    const decA = (a / Math.pow(10, decPlace));
                    const decB = (b / Math.pow(10, decPlace));
                    
                    const ans = op === '+' ? (decA + decB) : (decA - decB);
                    // Handle float precision
                    const cleanAns = parseFloat(ans.toPrecision(12)).toString();

                    return {
                        text: `${decA} ${op} ${decB}`,
                        answer: cleanAns,
                        type: 'standard',
                        displayAnswer: cleanAns
                    };
                }
                case 'dec_mul': {
                    const a = randomInt(1, 99) / 10;
                    const b = randomInt(1, 99) / 10;
                    const ans = parseFloat((a * b).toPrecision(12)).toString();
                    return {
                        text: `${a} × ${b}`,
                        answer: ans,
                        type: 'standard',
                        displayAnswer: ans
                    };
                }
                case 'dec_div': {
                    const divisor = randomInt(1, 9) / 10;
                    const quotient = randomInt(1, 99) / 10;
                    const dividend = parseFloat((divisor * quotient).toPrecision(12));
                    return {
                        text: `${dividend} ÷ ${divisor}`,
                        answer: quotient.toString(),
                        type: 'standard',
                        displayAnswer: quotient.toString()
                    };
                }
                case 'frac_add':
                case 'frac_sub': {
                    const op = topic === 'frac_add' ? '+' : '-';
                    let den = randomInt(2, 10);
                    let num1 = randomInt(1, den * 2);
                    let num2 = randomInt(1, den * 2);
                    
                    if (op === '-' && num2 > num1) { let t = num1; num1 = num2; num2 = t; }
                    
                    let ansNum = op === '+' ? num1 + num2 : num1 - num2;
                    let ansDen = den;
                    
                    // Simplify answer
                    let d = gcd(Math.abs(ansNum), ansDen);
                    ansNum /= d; ansDen /= d;

                    return {
                        text: <span className="flex items-center"><FractionDisplay num={num1} den={den} /> {op} <FractionDisplay num={num2} den={den} /></span>,
                        answer: { num: ansNum.toString(), den: ansDen.toString() },
                        type: 'fraction',
                        displayAnswer: <FractionDisplay num={ansNum} den={ansDen} />
                    };
                }
                case 'frac_mul':
                case 'frac_div': {
                    const op = topic === 'frac_mul' ? '×' : '÷';
                    let n1 = randomInt(1, 9), d1 = randomInt(2, 9);
                    let n2 = randomInt(1, 9), d2 = randomInt(2, 9);
                    
                    let ansNum, ansDen;
                    if (op === '×') {
                        ansNum = n1 * n2;
                        ansDen = d1 * d2;
                    } else {
                        ansNum = n1 * d2;
                        ansDen = d1 * n2;
                    }
                    
                    let d = gcd(Math.abs(ansNum), ansDen);
                    ansNum /= d; ansDen /= d;

                    return {
                        text: <span className="flex items-center"><FractionDisplay num={n1} den={d1} /> {op} <FractionDisplay num={n2} den={d2} /></span>,
                        answer: { num: ansNum.toString(), den: ansDen.toString() },
                        type: 'fraction',
                        displayAnswer: <FractionDisplay num={ansNum} den={ansDen} />
                    };
                }
                case 'frac_simplify': {
                    let mult = randomInt(2, 6);
                    let ansNum = randomInt(1, 5);
                    let ansDen = randomInt(ansNum + 1, 9); // Proper fraction
                    let startNum = ansNum * mult;
                    let startDen = ansDen * mult;

                    return {
                        text: <span className="flex items-center">Simplify: <FractionDisplay num={startNum} den={startDen} /></span>,
                        answer: { num: ansNum.toString(), den: ansDen.toString() },
                        type: 'fraction',
                        displayAnswer: <FractionDisplay num={ansNum} den={ansDen} />
                    };
                }
                case 'percentages': {
                    const type = randomInt(0, 2); // 0: find val, 1: find rate, 2: find base
                    let base = randomInt(2, 20) * 10; // 20 to 200
                    let rate = randomInt(1, 19) * 5; // 5% to 95%
                    let val = (base * rate) / 100;

                    if (type === 0) {
                        return { text: `What is ${rate}% of ${base}?`, answer: val.toString(), type: 'standard', displayAnswer: val.toString() };
                    } else if (type === 1) {
                        return { text: `${val} is what percent of ${base}?`, answer: rate.toString(), type: 'standard', displayAnswer: `${rate}%` };
                    } else {
                        return { text: `${val} is ${rate}% of what number?`, answer: base.toString(), type: 'standard', displayAnswer: base.toString() };
                    }
                }
                case 'exponents': {
                    let base = randomInt(2, 9);
                    let power = randomInt(0, 3);
                    let ans = Math.pow(base, power);
                    return {
                        text: <span>Evaluate: {base}<sup>{power}</sup></span>,
                        answer: ans.toString(),
                        type: 'standard',
                        displayAnswer: ans.toString()
                    };
                }
                case 'laws_exp': {
                    const ops = ['mul', 'div', 'pow'];
                    const op = ops[randomInt(0, 2)];
                    let p1 = randomInt(2, 6);
                    let p2 = randomInt(1, p1-1); // ensure positive division results
                    
                    if (op === 'mul') {
                        return {
                            text: <span>Simplify: x<sup>{p1}</sup> × x<sup>{p2}</sup></span>,
                            answer: (p1 + p2).toString(),
                            type: 'expression',
                            prefix: 'x^',
                            displayAnswer: <span>x<sup>{p1+p2}</sup></span>
                        };
                    } else if (op === 'div') {
                        return {
                            text: <span>Simplify: x<sup>{p1}</sup> ÷ x<sup>{p2}</sup></span>,
                            answer: (p1 - p2).toString(),
                            type: 'expression',
                            prefix: 'x^',
                            displayAnswer: <span>x<sup>{p1-p2}</sup></span>
                        };
                    } else {
                        return {
                            text: <span>Simplify: (x<sup>{p1}</sup>)<sup>{p2}</sup></span>,
                            answer: (p1 * p2).toString(),
                            type: 'expression',
                            prefix: 'x^',
                            displayAnswer: <span>x<sup>{p1*p2}</sup></span>
                        };
                    }
                }
                default:
                    return { text: '1 + 1', answer: '2', type: 'standard', displayAnswer: '2' };
            }
        };

        const CATEGORIES = [
            { id: 'whole_add', label: 'Whole Numbers: Addition', group: 'Whole Numbers' },
            { id: 'whole_sub', label: 'Whole Numbers: Subtraction', group: 'Whole Numbers' },
            { id: 'whole_mul', label: 'Whole Numbers: Multiplication', group: 'Whole Numbers' },
            { id: 'whole_div', label: 'Whole Numbers: Division', group: 'Whole Numbers' },
            { id: 'dec_add', label: 'Decimals: Addition', group: 'Decimals' },
            { id: 'dec_sub', label: 'Decimals: Subtraction', group: 'Decimals' },
            { id: 'dec_mul', label: 'Decimals: Multiplication', group: 'Decimals' },
            { id: 'dec_div', label: 'Decimals: Division', group: 'Decimals' },
            { id: 'frac_add', label: 'Fractions: Addition', group: 'Fractions' },
            { id: 'frac_sub', label: 'Fractions: Subtraction', group: 'Fractions' },
            { id: 'frac_mul', label: 'Fractions: Multiplication', group: 'Fractions' },
            { id: 'frac_div', label: 'Fractions: Division', group: 'Fractions' },
            { id: 'frac_simplify', label: 'Fractions: Simplify', group: 'Fractions' },
            { id: 'int_add', label: 'Integers: Addition', group: 'Integers' },
            { id: 'int_sub', label: 'Integers: Subtraction', group: 'Integers' },
            { id: 'int_mul', label: 'Integers: Multiplication', group: 'Integers' },
            { id: 'int_div', label: 'Integers: Division', group: 'Integers' },
            { id: 'percentages', label: 'Percentages (Base, Rate, Value)', group: 'Advanced' },
            { id: 'exponents', label: 'Exponents', group: 'Advanced' },
            { id: 'laws_exp', label: 'Laws of Exponents', group: 'Advanced' },
        ];


        const App = () => {
            const [screen, setScreen] = useState('home'); // home, settings, quiz, results, admin_login, admin_dashboard
            const [userName, setUserName] = useState('');
            const [topic, setTopic] = useState(null);
            const [authReady, setAuthReady] = useState(false);
            const [errorMsg, setErrorMsg] = useState('');

            // Settings State
            const [settings, setSettings] = useState({
                numQuestions: 10,
                digits: 2,
                regrouping: 'mixed',
                sign: 'mixed',
                table: 'mixed'
            });

            // Quiz State
            const [questions, setQuestions] = useState([]);
            const [currentIndex, setCurrentIndex] = useState(0);
            const [score, setScore] = useState(0);
            const [currentTries, setCurrentTries] = useState(0);
            const [quizStatus, setQuizStatus] = useState('playing'); // playing, wrong, failed, success
            
            // User Inputs
            const [stdInput, setStdInput] = useState('');
            const [fracInput, setFracInput] = useState({ num: '', den: '' });

            // Admin State
            const [adminPass, setAdminPass] = useState('');
            const [adminData, setAdminData] = useState([]);
            const [adminLoading, setAdminLoading] = useState(false);

            useEffect(() => {
                const initAuth = async () => {
                    try {
                        const { auth, signInAnonymously, signInWithCustomToken, initialAuthToken } = window.FirebaseApp;
                        if (initialAuthToken) {
                            await signInWithCustomToken(auth, initialAuthToken);
                        } else {
                            await signInAnonymously(auth);
                        }
                        setAuthReady(true);
                    } catch (error) {
                        console.error("Auth error:", error);
                        setErrorMsg("Could not connect to database. Progress won't be saved.");
                        setAuthReady(true); // Let them play anyway
                    }
                };
                initAuth();
            }, []);

            const startSettings = (selectedTopic) => {
                if (!userName.trim()) {
                    setErrorMsg("Please enter your name first.");
                    setTimeout(() => setErrorMsg(''), 3000);
                    return;
                }
                setTopic(selectedTopic);
                // Reset defaults based on topic
                let defaultDigits = 2;
                if (selectedTopic.includes('dec')) defaultDigits = 1; // 1 decimal place generation baseline
                setSettings({ ...settings, digits: defaultDigits, regrouping: 'mixed', sign: 'mixed', table: 'mixed', numQuestions: 10 });
                setScreen('settings');
            };

            const startQuiz = () => {
                const generated = [];
                for (let i = 0; i < settings.numQuestions; i++) {
                    generated.push(generateQuestion(topic.id, settings));
                }
                setQuestions(generated);
                setCurrentIndex(0);
                setScore(0);
                setCurrentTries(0);
                setQuizStatus('playing');
                resetInputs();
                setScreen('quiz');
            };

            const resetInputs = () => {
                setStdInput('');
                setFracInput({ num: '', den: '' });
            };

            const cancelQuiz = () => {
                if(confirm("Are you sure you want to cancel? Your progress will be lost.")) {
                    setScreen('home');
                }
            };

            const checkAnswer = () => {
                const q = questions[currentIndex];
                let isCorrect = false;

                if (q.type === 'standard' || q.type === 'expression') {
                    // Tolerant to extra spaces, case insensitive
                    isCorrect = stdInput.trim().toLowerCase() === q.answer.toString().toLowerCase();
                } else if (q.type === 'fraction') {
                    // Note: for fractions we require exact simplified match based on generator
                    // but we can allow 2/-3 == -2/3. For simplicity, match strictly what's generated.
                    // Wait, sometimes generator output might be num:1, den:1. Let's allow simple matches.
                    const inNum = parseInt(fracInput.num);
                    const inDen = parseInt(fracInput.den) || 1;
                    const ansNum = parseInt(q.answer.num);
                    const ansDen = parseInt(q.answer.den);

                    // Cross multiply check for equivalence AND check if simplified if it's simplify category
                    if (topic.id === 'frac_simplify') {
                         isCorrect = (inNum === ansNum && inDen === ansDen);
                    } else {
                         // General fraction equivalence 
                         if (inDen !== 0 && (inNum * ansDen === ansNum * inDen)) {
                            isCorrect = true;
                         }
                    }
                }

                if (isCorrect) {
                    setQuizStatus('success');
                    if (currentTries === 0) {
                        setScore(score + 1);
                    }
                } else {
                    const newTries = currentTries + 1;
                    setCurrentTries(newTries);
                    if (newTries >= 2) {
                        setQuizStatus('failed');
                    } else {
                        setQuizStatus('wrong');
                    }
                }
            };

            const nextQuestion = () => {
                if (currentIndex + 1 < questions.length) {
                    setCurrentIndex(currentIndex + 1);
                    setCurrentTries(0);
                    setQuizStatus('playing');
                    resetInputs();
                } else {
                    finishQuiz();
                }
            };

            const finishQuiz = async () => {
                setScreen('results');
                
                // Save to Firestore
                const { db, auth, appId, collection, addDoc } = window.FirebaseApp;
                if (auth.currentUser) {
                    try {
                        const path = collection(db, 'artifacts', appId, 'public', 'data', 'math_scores');
                        await addDoc(path, {
                            name: userName,
                            topic: topic.label,
                            score: (quizStatus === 'success' && currentTries === 0 && currentIndex === questions.length-1) ? score + 1 : score, // account for last correct answer if state hasn't flushed
                            total: questions.length,
                            timestamp: new Date().toISOString()
                        });
                    } catch (e) {
                        console.error("Failed to save score:", e);
                    }
                }
            };

            const handleAdminLogin = (e) => {
                e.preventDefault();
                if (adminPass === 'Admin1') {
                    setScreen('admin_dashboard');
                    setAdminPass('');
                    fetchAdminData();
                } else {
                    alert("Incorrect Password");
                }
            };

            const fetchAdminData = async () => {
                setAdminLoading(true);
                const { db, auth, appId, collection, getDocs } = window.FirebaseApp;
                if (!auth.currentUser) {
                    setAdminLoading(false);
                    return;
                }
                try {
                    const path = collection(db, 'artifacts', appId, 'public', 'data', 'math_scores');
                    const snapshot = await getDocs(path);
                    const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                    // Sort descending by timestamp in memory (Rule 2)
                    data.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
                    setAdminData(data);
                } catch (e) {
                    console.error("Admin fetch error", e);
                }
                setAdminLoading(false);
            };

            if (screen === 'home') {
                // Group categories
                const groups = CATEGORIES.reduce((acc, cat) => {
                    if (!acc[cat.group]) acc[cat.group] = [];
                    acc[cat.group].push(cat);
                    return acc;
                }, {});

                return (
                    <div className="min-h-screen bg-gray-100 flex flex-col items-center py-10 px-4">
                        <div className="w-full max-w-4xl bg-white rounded-2xl shadow-xl overflow-hidden relative">
                            <button onClick={() => setScreen('admin_login')} className="absolute top-4 right-4 text-xs font-semibold text-gray-400 hover:text-gray-800 transition">Admin Panel</button>
                            
                            <div className="bg-blue-600 p-8 text-center text-white">
                                <h1 className="text-3xl md:text-4xl font-bold mb-2">Math Practice Pro</h1>
                                <p className="text-blue-100">Master your math skills step by step.</p>
                            </div>

                            <div className="p-8">
                                <div className="mb-8 max-w-md mx-auto">
                                    <label className="block text-sm font-semibold text-gray-700 mb-2">Student Name</label>
                                    <input 
                                        type="text" 
                                        value={userName}
                                        onChange={(e) => setUserName(e.target.value)}
                                        placeholder="Enter your name to start..."
                                        className="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none shadow-sm transition"
                                    />
                                    {errorMsg && <p className="text-red-500 text-sm mt-2 font-medium">{errorMsg}</p>}
                                </div>

                                <h2 className="text-xl font-bold text-gray-800 mb-6 text-center border-b pb-2">Select a Topic</h2>
                                
                                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                    {Object.entries(groups).map(([groupName, cats]) => (
                                        <div key={groupName} className="bg-gray-50 rounded-xl p-4 border border-gray-200">
                                            <h3 className="font-bold text-gray-700 mb-3 text-sm uppercase tracking-wider">{groupName}</h3>
                                            <div className="space-y-2">
                                                {cats.map(c => (
                                                    <button 
                                                        key={c.id} 
                                                        onClick={() => startSettings(c)}
                                                        className="w-full text-left px-3 py-2 rounded-lg hover:bg-blue-100 hover:text-blue-800 transition text-sm font-medium text-gray-600 bg-white shadow-sm border border-gray-100"
                                                    >
                                                        {c.label}
                                                    </button>
                                                ))}
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>
                );
            }

            if (screen === 'settings') {
                return (
                    <div className="min-h-screen bg-gray-100 flex items-center justify-center p-4">
                        <div className="w-full max-w-lg bg-white rounded-2xl shadow-xl p-8">
                            <h2 className="text-2xl font-bold text-gray-800 mb-6 text-center">{topic.label} Settings</h2>
                            
                            <div className="space-y-5">
                                {/* Number of Questions */}
                                <div>
                                    <label className="block text-sm font-semibold text-gray-700 mb-1">Number of Questions</label>
                                    <select 
                                        value={settings.numQuestions}
                                        onChange={e => setSettings({...settings, numQuestions: parseInt(e.target.value)})}
                                        className="w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                    >
                                        <option value="5">5</option>
                                        <option value="10">10</option>
                                        <option value="15">15</option>
                                        <option value="20">20</option>
                                        <option value="30">30</option>
                                    </select>
                                </div>

                                {/* Digits (for whole numbers, decimals, integers) */}
                                {(topic.id.includes('whole_') || topic.id.includes('dec_') || topic.id.includes('int_')) && (
                                    <div>
                                        <label className="block text-sm font-semibold text-gray-700 mb-1">Number of Digits</label>
                                        <select 
                                            value={settings.digits}
                                            onChange={e => setSettings({...settings, digits: parseInt(e.target.value)})}
                                            className="w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                        >
                                            <option value="1">1 Digit</option>
                                            <option value="2">2 Digits</option>
                                            <option value="3">3 Digits</option>
                                            <option value="4">4 Digits</option>
                                        </select>
                                    </div>
                                )}

                                {/* Regrouping (for addition/subtraction of whole/dec/int) */}
                                {['whole_add', 'whole_sub', 'dec_add', 'dec_sub', 'int_add', 'int_sub'].includes(topic.id) && (
                                    <div>
                                        <label className="block text-sm font-semibold text-gray-700 mb-1">Regrouping (Borrowing/Carrying)</label>
                                        <select 
                                            value={settings.regrouping}
                                            onChange={e => setSettings({...settings, regrouping: e.target.value})}
                                            className="w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                        >
                                            <option value="mixed">Mixed (Random)</option>
                                            <option value="no">Without Regrouping</option>
                                            <option value="yes">With Regrouping</option>
                                        </select>
                                    </div>
                                )}

                                {/* Sign (for integers) */}
                                {topic.id.includes('int_') && (
                                    <div>
                                        <label className="block text-sm font-semibold text-gray-700 mb-1">Signs Included</label>
                                        <select 
                                            value={settings.sign}
                                            onChange={e => setSettings({...settings, sign: e.target.value})}
                                            className="w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                        >
                                            <option value="mixed">Both Positive & Negative</option>
                                            <option value="positive">Positive Only</option>
                                            <option value="negative">Negative Only</option>
                                        </select>
                                    </div>
                                )}

                                {/* Tables (for multiplication/division of whole/integers) */}
                                {['whole_mul', 'whole_div', 'int_mul', 'int_div'].includes(topic.id) && (
                                    <div>
                                        <label className="block text-sm font-semibold text-gray-700 mb-1">Times Tables (1-12)</label>
                                        <select 
                                            value={settings.table}
                                            onChange={e => setSettings({...settings, table: e.target.value})}
                                            className="w-full px-3 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                                        >
                                            <option value="mixed">Mixed</option>
                                            {[...Array(12)].map((_, i) => (
                                                <option key={i+1} value={i+1}>Table of {i+1}</option>
                                            ))}
                                        </select>
                                    </div>
                                )}
                            </div>

                            <div className="flex gap-4 mt-8">
                                <button onClick={() => setScreen('home')} className="flex-1 py-3 bg-gray-200 text-gray-800 rounded-lg font-bold hover:bg-gray-300 transition">Back</button>
                                <button onClick={startQuiz} className="flex-1 py-3 bg-blue-600 text-white rounded-lg font-bold hover:bg-blue-700 transition">Start Practice</button>
                            </div>
                        </div>
                    </div>
                );
            }

            if (screen === 'quiz') {
                const q = questions[currentIndex];
                const isFinished = quizStatus === 'success' || quizStatus === 'failed';

                return (
                    <div className="min-h-screen bg-gray-100 flex flex-col items-center justify-center p-4">
                        <div className="w-full max-w-2xl bg-white rounded-2xl shadow-xl overflow-hidden flex flex-col min-h-[400px]">
                            
                            {/* Header */}
                            <div className="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                                <div className="text-gray-500 font-semibold text-sm">Question {currentIndex + 1} of {questions.length}</div>
                                <button onClick={cancelQuiz} className="text-red-500 hover:text-red-700 font-semibold text-sm transition">Cancel</button>
                            </div>

                            {/* Main Content Area */}
                            <div className="flex-1 p-8 flex flex-col items-center justify-center">
                                <h2 className="text-4xl font-bold text-gray-800 mb-10 flex items-center justify-center text-center">
                                    {q.text} <span className="mx-4">=</span> ?
                                </h2>

                                {/* Input Area */}
                                <div className="mb-8 w-full flex justify-center">
                                    {q.type === 'standard' && (
                                        <input 
                                            type="text" 
                                            value={stdInput}
                                            onChange={e => setStdInput(e.target.value)}
                                            onKeyDown={e => e.key === 'Enter' && !isFinished && checkAnswer()}
                                            disabled={isFinished}
                                            className="text-center text-3xl w-48 px-4 py-3 border-2 border-gray-300 rounded-xl focus:border-blue-500 focus:outline-none transition shadow-inner"
                                            autoFocus
                                        />
                                    )}
                                    
                                    {q.type === 'expression' && (
                                        <div className="flex items-center text-3xl font-bold">
                                            <span className="mr-1">x</span><sup className="mt-[-20px]">
                                                <input 
                                                    type="text" 
                                                    value={stdInput}
                                                    onChange={e => setStdInput(e.target.value)}
                                                    onKeyDown={e => e.key === 'Enter' && !isFinished && checkAnswer()}
                                                    disabled={isFinished}
                                                    className="text-center w-16 px-1 py-1 border-2 border-gray-300 rounded focus:border-blue-500 focus:outline-none text-xl shadow-inner"
                                                    autoFocus
                                                />
                                            </sup>
                                        </div>
                                    )}

                                    {q.type === 'fraction' && (
                                        <div className="flex flex-col items-center gap-2">
                                            <input 
                                                type="number" 
                                                value={fracInput.num}
                                                onChange={e => setFracInput({...fracInput, num: e.target.value})}
                                                onKeyDown={e => e.key === 'Enter' && !isFinished && checkAnswer()}
                                                disabled={isFinished}
                                                className="text-center text-2xl w-24 px-2 py-1 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition shadow-inner"
                                                placeholder="num"
                                                autoFocus
                                            />
                                            <div className="h-1 w-24 bg-gray-800 rounded"></div>
                                            <input 
                                                type="number" 
                                                value={fracInput.den}
                                                onChange={e => setFracInput({...fracInput, den: e.target.value})}
                                                onKeyDown={e => e.key === 'Enter' && !isFinished && checkAnswer()}
                                                disabled={isFinished}
                                                className="text-center text-2xl w-24 px-2 py-1 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition shadow-inner"
                                                placeholder="den"
                                            />
                                        </div>
                                    )}
                                </div>

                                {/* Status Messages */}
                                {quizStatus === 'wrong' && (
                                    <div className="text-orange-500 font-bold mb-4 animate-bounce">Incorrect. You have 1 try left!</div>
                                )}
                                {quizStatus === 'success' && (
                                    <div className="text-green-500 font-bold text-xl mb-4 bg-green-100 px-6 py-2 rounded-full border border-green-200">Correct! Great job.</div>
                                )}
                                {quizStatus === 'failed' && (
                                    <div className="flex flex-col items-center text-red-500 font-bold mb-4">
                                        <span className="mb-2">Incorrect. The correct answer is:</span>
                                        <div className="text-3xl text-gray-800 bg-gray-100 px-6 py-3 rounded-xl border border-gray-300">
                                            {q.displayAnswer}
                                        </div>
                                    </div>
                                )}
                            </div>

                            {/* Footer Actions */}
                            <div className="bg-gray-50 px-6 py-4 border-t border-gray-200 flex justify-end">
                                {!isFinished ? (
                                    <button 
                                        onClick={checkAnswer}
                                        className="px-8 py-3 bg-blue-600 text-white rounded-xl font-bold shadow hover:bg-blue-700 transition active:scale-95"
                                    >
                                        Check Answer
                                    </button>
                                ) : (
                                    <button 
                                        onClick={nextQuestion}
                                        className="px-8 py-3 bg-green-600 text-white rounded-xl font-bold shadow hover:bg-green-700 transition active:scale-95"
                                        autoFocus
                                    >
                                        {currentIndex + 1 < questions.length ? 'Next Question' : 'Finish Practice'}
                                    </button>
                                )}
                            </div>
                        </div>
                    </div>
                );
            }

            if (screen === 'results') {
                const percentage = Math.round((score / questions.length) * 100);
                let message = "Keep practicing!";
                if (percentage >= 90) message = "Outstanding Work!";
                else if (percentage >= 70) message = "Great Job!";
                else if (percentage >= 50) message = "Good Effort!";

                return (
                    <div className="min-h-screen bg-blue-600 flex items-center justify-center p-4">
                        <div className="w-full max-w-md bg-white rounded-3xl shadow-2xl p-10 text-center relative overflow-hidden">
                            <div className="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-blue-50 to-white"></div>
                            <div className="relative z-10">
                                <h2 className="text-3xl font-bold text-gray-800 mb-2">{message}</h2>
                                <p className="text-gray-500 mb-8 font-medium">{userName}, here is your result for {topic.label}.</p>
                                
                                <div className="mb-10 relative inline-block">
                                    <svg className="w-40 h-40 transform -rotate-90">
                                        <circle cx="80" cy="80" r="70" stroke="currentColor" strokeWidth="12" fill="transparent" className="text-gray-200" />
                                        <circle cx="80" cy="80" r="70" stroke="currentColor" strokeWidth="12" fill="transparent" strokeDasharray="440" strokeDashoffset={440 - (440 * percentage) / 100} className={`${percentage >= 70 ? 'text-green-500' : (percentage >= 50 ? 'text-yellow-400' : 'text-red-500')} transition-all duration-1000 ease-out`} />
                                    </svg>
                                    <div className="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
                                        <span className="text-4xl font-extrabold text-gray-800">{score}</span>
                                        <span className="text-sm font-semibold text-gray-400 border-t-2 border-gray-200 pt-1 w-12 text-center mt-1">{questions.length}</span>
                                    </div>
                                </div>

                                <button 
                                    onClick={() => setScreen('home')}
                                    className="w-full py-4 bg-gray-900 text-white rounded-xl font-bold shadow-lg hover:bg-gray-800 transition active:scale-95"
                                >
                                    Back to Home
                                </button>
                            </div>
                        </div>
                    </div>
                );
            }

            if (screen === 'admin_login') {
                return (
                    <div className="min-h-screen bg-gray-900 flex items-center justify-center p-4">
                        <form onSubmit={handleAdminLogin} className="bg-white p-8 rounded-2xl shadow-xl w-full max-w-sm">
                            <h2 className="text-2xl font-bold mb-6 text-center text-gray-800">Admin Access</h2>
                            <input 
                                type="password" 
                                value={adminPass}
                                onChange={e => setAdminPass(e.target.value)}
                                placeholder="Enter Password"
                                className="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none mb-6"
                                autoFocus
                            />
                            <div className="flex gap-3">
                                <button type="button" onClick={() => setScreen('home')} className="flex-1 py-3 bg-gray-200 text-gray-800 font-bold rounded-lg hover:bg-gray-300 transition">Cancel</button>
                                <button type="submit" className="flex-1 py-3 bg-gray-900 text-white font-bold rounded-lg hover:bg-black transition">Login</button>
                            </div>
                        </form>
                    </div>
                );
            }

            if (screen === 'admin_dashboard') {
                return (
                    <div className="min-h-screen bg-gray-50 flex flex-col">
                        <div className="bg-gray-900 text-white p-4 shadow-md flex justify-between items-center sticky top-0 z-10">
                            <h1 className="text-xl font-bold flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" className="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Admin Dashboard
                            </h1>
                            <button onClick={() => setScreen('home')} className="px-4 py-2 bg-gray-700 hover:bg-gray-600 rounded-lg text-sm font-semibold transition">Back to App</button>
                        </div>
                        
                        <div className="flex-1 p-6 lg:p-10 max-w-6xl mx-auto w-full">
                            <div className="flex justify-between items-end mb-6">
                                <div>
                                    <h2 className="text-2xl font-bold text-gray-800">Student Scores</h2>
                                    <p className="text-gray-500 text-sm mt-1">Review performance across all topics.</p>
                                </div>
                                <button onClick={fetchAdminData} className="text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1 text-sm bg-blue-50 px-3 py-2 rounded">
                                    <svg xmlns="http://www.w3.org/2000/svg" className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                    </svg> Refresh
                                </button>
                            </div>

                            <div className="bg-white rounded-xl shadow border border-gray-200 overflow-hidden">
                                {adminLoading ? (
                                    <div className="p-10 text-center text-gray-500 font-medium animate-pulse">Loading records...</div>
                                ) : adminData.length === 0 ? (
                                    <div className="p-10 text-center text-gray-500 font-medium">No records found.</div>
                                ) : (
                                    <div className="overflow-x-auto custom-scrollbar">
                                        <table className="w-full text-left border-collapse">
                                            <thead>
                                                <tr className="bg-gray-100 text-gray-700 text-sm uppercase tracking-wider">
                                                    <th className="p-4 font-semibold border-b">Date/Time</th>
                                                    <th className="p-4 font-semibold border-b">Student Name</th>
                                                    <th className="p-4 font-semibold border-b">Category / Topic</th>
                                                    <th className="p-4 font-semibold border-b text-right">Score</th>
                                                    <th className="p-4 font-semibold border-b text-center">%</th>
                                                </tr>
                                            </thead>
                                            <tbody className="divide-y divide-gray-100">
                                                {adminData.map(record => {
                                                    const date = new Date(record.timestamp);
                                                    const perc = Math.round((record.score / record.total) * 100);
                                                    return (
                                                        <tr key={record.id} className="hover:bg-gray-50 transition">
                                                            <td className="p-4 text-sm text-gray-500 whitespace-nowrap">
                                                                {date.toLocaleDateString()} <span className="text-xs">{date.toLocaleTimeString()}</span>
                                                            </td>
                                                            <td className="p-4 font-medium text-gray-800">{record.name}</td>
                                                            <td className="p-4 text-sm text-gray-600">
                                                                <span className="bg-blue-50 text-blue-700 px-2 py-1 rounded text-xs font-semibold">{record.topic}</span>
                                                            </td>
                                                            <td className="p-4 text-right font-bold text-gray-700">
                                                                {record.score} <span className="text-gray-400 font-medium">/ {record.total}</span>
                                                            </td>
                                                            <td className="p-4 text-center">
                                                                <span className={`inline-block px-2 py-1 rounded text-xs font-bold ${perc >= 80 ? 'bg-green-100 text-green-800' : (perc >= 50 ? 'bg-yellow-100 text-yellow-800' : 'bg-red-100 text-red-800')}`}>
                                                                    {perc}%
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    )
                                                })}
                                            </tbody>
                                        </table>
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                );
            }

            return null;
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
